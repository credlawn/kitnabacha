# Supabase connection string for your self-hosted Docker PostgreSQL database.
# Replace with your actual database password and domain name.
SUPABASE_DB_URL="postgresql://postgres:<your-db-password>@<your-domain-name>:54322/postgres"

# Supabase Project Credentials (required for the Flutter app)
# Using secure HTTPS since a domain is configured.
SUPABASE_URL="https://<your-domain-name>"
SUPABASE_ANON_KEY="your-anon-key-here"
